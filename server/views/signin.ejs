<!DOCTYPE html>
<html>
<head>
  <title>Signin</title>
  <%- include("./partials/head.ejs") %>
</head>
<body>

<div class="container mt-5">
  <h2>Signin</h2>

  <% if (message) { %>
    <div class="alert alert-danger"><%= message %></div>
  <% } %>

  <form action="/signin" method="post">
    <input name="user_email" class="form-control mb-2" placeholder="Email" />
    <input type="password" name="user_password" class="form-control mb-2" placeholder="Password" />

    <button class="btn btn-success">Signin</button>
  </form>

  <p class="mt-3">No account? <a href="/signup">Signup</a></p>
</div>

</body>
</html>